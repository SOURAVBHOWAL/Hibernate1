package NonPrimitiveTypecastingCarExample;

import java.util.Scanner;

public class DriverClass {
	static Scanner sc=new Scanner(System.in);
	public static void main(String[] args) {
		Car c=new Car();
		Engine e;
		System.out.print("Enter 1 for Petrol and 2 for Diesel: ");
		int choice=sc.nextInt();
		switch(choice) {
		case 1:
			e=new PetrolEngine();
			PetrolEngine pe=(PetrolEngine)e;
			c.eng=pe;
			//pe.fuelType();
			
			break;
		case 2:
			c.eng=new DieselEngine();
			break;
		default:
			c.eng=new PetrolEngine();
			break;
		}
		System.out.println(c.eng.getClass());
	}

}
