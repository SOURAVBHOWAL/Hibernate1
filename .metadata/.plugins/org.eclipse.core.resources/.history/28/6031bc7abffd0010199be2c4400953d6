
public class Stack1 {
	int top=-1;
	static final int size=10;
	int[] stk;
	
	public boolean push(int n) {
		if(top==-1) {
			stk=new int[size];
			top++;
			stk[top]=n;
		}
		else if(top==size-1) {
//			System.out.println("Overflow");
			return false;
		}
		else {
			top++;
			stk[top]=n;
		}
		return true;
	}
	public boolean pop() {
		if(top==-1) {
//			System.out.println("Empty");
			return false;
		}
		else {
			top--;
			return true;
		}
	}
	public  int peek() {
		if(top==-1) {
			return -1;
		}
		else {
			 return stk[top];
		}
	}
	public boolean isEmpty() {
		if(top==-1) {
			return false;
		}
		return false;
	}
	
	
	public static void main(String[] args) {
		Stack1 s=new Stack1();
		s.push(1);
		s.push(2);
		s.push(8);
		s.push(6);
//		System.out.println(s.peek());
		while(!s.isEmpty()) {
			System.out.println(s.peek());
			s.pop();			
		}

	}

}
