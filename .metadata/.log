	}
	static void matPrint(int[][] mat) {
		for(int i=0;i<mat.length;i++) {
			for(int j=0;j<mat[i].length;j++) {
				System.out.print(mat[i][j]+" ");
			}
			System.out.println();
		}
	}
	static void isColumnMatrix(int[][] mat) {
		(mat.length>=1)? (mat[0].length==1)? System.out.println("Column Matrix"):System.out.println(" Non Column Matrix"):System.out.println("Invalid Matrix");
	}

}

